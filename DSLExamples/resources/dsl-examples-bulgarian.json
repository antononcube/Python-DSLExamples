    "Tabular": {
      "покажи размерности": "Echo[Dimensions[obj]]",
      "кръстосана таблица passenger_sex с passenger_survival": "obj = PivotTable[obj, Length @ #[\"passenger_sex\"] &, \"passenger_sex\", \"passenger_survival\"]",
      "преименувай колоните passengerAge на age, passengerSex на sex и passengerClass на class": "obj = RenameColumns[obj, {\"passengerAge\" -> \"age\", \"passengerSex\" -> \"sex\", \"passengerClass\" -> \"class\"}]",
      "трансформирай липсващи стойности чрез интерполация": "obj = TransformMissing[obj, Automatic -> \"Interpolation\"]",
      "раздели колоната name по PAT в колоните maker и model": "obj = TransformColumns[obj, {\"maker\", \"model\"} -> Function[StringSplit[#name, 2]]]",
      "брой": "obj = Length /@ obj",
      "филтрирай редовете с passengerAge > 29": "obj = Discard[obj, #passengerAge > 29&]",
      "замени липсващите в VAR1 със средно и в VAR23 с медиана": "obj = TransformMissing[obj, {\"VAR1\" -> \"Mean\", \"VAR23\" -> \"Median\"}]",
      "използвай набора от данни dfTitanic": "obj = Tabular[dfTitanic]",
      "покажи колоните на tblTrees": "ColumnKeys[tblTrees]",
      "трансформирай поелементно с функцията QuantityMagnitude ако елементът удовлетворява QuantityQ": "obj = ToTabular@\n  Elementwise[If[QuantityQ[#], QuantityMagnitude[#], #] &][obj]",
      "групирай по passengerSex и passengerClass": "obj = GroupBy[obj, {#1[\"passengerSex\"], #1[\"passengerClass\"]} &];",
      "покажи обобщение на данните": "Echo[TabularStructure[obj]]",
      "сортирай по mass / height ^ 2": "obj = ReverseSortBy[obj, #mass / #height^2 &]",
      "покажи агрегирани стойности (Mean @ #passengerAge) по passengerSex и passengerSurvival": "Echo @ AggregateRows[obj, {\"mean\" -> (Mean @ #passengerAge] &)}, {\"passengerSex\",\n   \"passengerClass\"}]",
      "зареди CSV файла ~/Downloads/data.CSV": "obj = Import[\"~/Downloads/data.CSV\",\"Tabular\"]",
      "сортирай низходящо по passengerAge": "obj = ReverseSortBy[obj, #passengerAge&]",
      "обобщи данните": "obj = TabularStructure[obj]",
      "филтрирай по passengerAge по-голямо от 12": "obj = Select[obj, #1[\"passengerAge\"] > 12 &]",
      "раздели колоната name по PAT в maker и model и премахни name": "obj = TransformColumns[obj, {\"maker\", \"model\"} -> Function[StringSplit[#name, 2]], \"name\" -> Nothing]",
      "покажи типовете колони на tblTrees": "ColumnType[tblTrees]",
      "замени липсващите стойности в VAR1 със средно": "obj = TransformMissing[obj, \"VAR1\" -> \"Mean\"]",
      "кръстосана таблица passengerSex със passengerSurvival по passengerAge": "obj = PivotTable[obj, Total@#passengerAge &, \"passengerSex\", \"passengerSurvival\"]",
      "комбинирай колоните latitude и longitude на tblTrees чрез FUNC в geoLocation": "tblTrees = TransformColumns[tblTrees, \"geoLocation\" -> FUNC[#latitude, #longitude]]",
      "замени липсващите стойности в колоната NAME54 с \"MyNA\"": "obj = TransformMissing[obj, \"NAME54\" -> {\"Constant\", \"MyNA\"}]",
      "категоризирай колоната passengerSex": "obj = CastColumns[obj, \"passengerSex\" -> \"Categorical\"]",
      "комбинирай latitude и longitude чрез FUNC в geoLocation": "obj = TransformColumns[obj, \"geoLocation\" -> FUNC[#latitude, #longitude]]",
      "покажи броя": "Echo[Length /@ obj, \"counts:\"]",
      "запази редовете с passenger_class = 1st": "obj = Select[obj, #[\"passenger_class\"] == \"1st\"&]",
      "трансформирай поелементно с функцията FF12": "obj = ToTabular @ Elementwise[FF12][obj]",
      "премахни колоните passengerAge и passengerSex": "obj = DeleteColumns[obj, {\"passengerAge\", \"passengerSex\"}]",
      "кръстосана таблица passengerSex с passengerSurvival с групови агрегати": "obj = PivotTable[obj, Length@#passengerSex &, \"passengerSex\", \"passengerSurvival\", \"IncludeGroupAggregates\" -> True]"
    },
