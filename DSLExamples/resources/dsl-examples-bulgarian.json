      "категоризирай колоната passengerSex": "obj['passengerSex'] = obj['passengerSex'].astype('category')",
      "трансформирай поелементно с функцията FF12": "obj = obj.applymap(FF12)",
      "замени липсващите стойности в колоната NAME54 с 'MyNA'": "obj['NAME54'] = obj['NAME54'].fillna('MyNA')",
