      "renomeie as colunas passengerAge como age, passengerSex como sex, e passengerClass como class": "obj = RenameColumns[obj, {\"passengerAge\" -> \"age\", \"passengerSex\" -> \"sex\", \"passengerClass\" -> \"class\"}]",
      "mostre as dimensões": "Echo[Dimensions[obj]]",
      "ordene de forma decrescente por passengerAge": "obj = ReverseSortBy[obj, #passengerAge&]",
      "categorize a coluna passengerSex": "obj = CastColumns[obj, \"passengerSex\" -> \"Categorical\"]",
      "faça a tabulação cruzada de passengerSex com passengerSurvival sobre passengerAge": "obj = PivotTable[obj, Total@#passengerAge &, \"passengerSex\", \"passengerSurvival\"]",
      "combine as colunas latitude e longitude com FUNC na coluna geoLocation": "obj = TransformColumns[obj, \"geoLocation\" -> FUNC[#latitude, #longitude]]",
      "mantenha apenas as linhas em que passenger_class é 1st": "obj = Select[obj, #[\"passenger_class\"] == \"1st\"&]",
      "transforme ausentes de VAR1 pela média e de VAR23 pela mediana": "obj = TransformMissing[obj, {\"VAR1\" -> \"Mean\", \"VAR23\" -> \"Median\"}]",
      "filtre as linhas que têm passengerAge maior que 29": "obj = Discard[obj, #passengerAge > 29&]",
      "divida a coluna name usando PAT nas colunas maker e model": "obj = TransformColumns[obj, {\"maker\", \"model\"} -> Function[StringSplit[#name, 2]]]",
      "transforme elemento a elemento usando a função QuantityMagnitude se o elemento satisfaz QuantityQ": "obj = ToTabular@\n  Elementwise[If[QuantityQ[#], QuantityMagnitude[#], #] &][obj]",
      "filtre por passengerAge maior que 12": "obj = Select[obj, #1[\"passengerAge\"] > 12 &]",
      "transforme valores ausentes por interpolação": "obj = TransformMissing[obj, Automatic -> \"Interpolation\"]",
      "remova as colunas passengerAge e passengerSex": "obj = DeleteColumns[obj, {\"passengerAge\", \"passengerSex\"}]",
      "mostre as colunas de tblTrees": "ColumnKeys[tblTrees]",
      "combine as colunas latitude e longitude de tblTrees usando FUNC na coluna geoLocation": "tblTrees = TransformColumns[tblTrees, \"geoLocation\" -> FUNC[#latitude, #longitude]]",
      "substitua os valores ausentes da coluna NAME54 pela constante \"MyNA\"": "obj = TransformMissing[obj, \"NAME54\" -> {\"Constant\", \"MyNA\"}]",
      "contagens": "obj = Length /@ obj",
      "resuma os dados": "obj = TabularStructure[obj]",
      "use o conjunto de dados dfTitanic": "obj = Tabular[dfTitanic]"
    },
